{
  "name": "@general-liquidity/opensolvency",
  "version": "0.1.7",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "description": "The operator-aligned governance plane for agentic spend. The 'secure enclave' of the money OS: a payment is structurally unable to execute outside an operator-granted mandate, and every decision is signed and replayable.",
  "license": "MIT",
  "author": "General Liquidity",
  "homepage": "https://github.com/general-liquidity/opensolvency#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/general-liquidity/opensolvency.git"
  },
  "bugs": {
    "url": "https://github.com/general-liquidity/opensolvency/issues"
  },
  "keywords": [
    "agentic-payments",
    "governance",
    "ai-agents",
    "mcp",
    "acp",
    "x402",
    "personal-finance"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "opensolvency": "dist/cli/index.js"
  },
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/run.d.ts",
      "import": "./dist/mcp/run.js"
    },
    "./integrations": {
      "types": "./dist/integrations/index.d.ts",
      "import": "./dist/integrations/index.js"
    },
    "./gate": {
      "types": "./dist/portable.d.ts",
      "import": "./dist/portable.js"
    },
    "./disclosure": {
      "types": "./dist/disclosure/index.d.ts",
      "import": "./dist/disclosure/index.js"
    },
    "./ap2": {
      "types": "./dist/ap2/index.d.ts",
      "import": "./dist/ap2/index.js"
    },
    "./agui": {
      "types": "./dist/agui/index.d.ts",
      "import": "./dist/agui/index.js"
    },
    "./erc7710": {
      "types": "./dist/erc7710/index.d.ts",
      "import": "./dist/erc7710/index.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.js"
    },
    "./compliance": {
      "types": "./dist/compliance/index.d.ts",
      "import": "./dist/compliance/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "eval-gate": "node --import tsx scripts/eval-gate.ts",
    "testnet-settle": "node --import tsx scripts/testnet-settle.ts",
    "example:shopping": "node --import tsx examples/shopping-agent.ts",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "lint": "biome lint",
    "format": "biome format --write",
    "format:check": "biome format",
    "typecheck": "tsc --noEmit",
    "demo": "node --import tsx scripts/demo.ts",
    "cli": "node --import tsx src/cli/index.ts",
    "acp": "node --import tsx src/cli/index.ts acp",
    "mcp": "node --import tsx src/cli/index.ts mcp",
    "serve": "node --import tsx src/cli/index.ts serve"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^24",
    "tsx": "^4.19.0",
    "typescript": "^6",
    "viem": "^2.53.1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@general-liquidity/agent-disclosure": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^7.0.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "dinero.js": "^1.9.1",
    "http-message-signatures": "^1.0.4",
    "viem": "^2.53.1"
  }
}
